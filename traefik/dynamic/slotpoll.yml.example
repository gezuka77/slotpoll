http:
  routers:
    slotpoll:
      rule: "Host(`slotpoll.yourdomain.com`)"
      service: slotpoll-service
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - secure-headers

    traefik-dashboard:
      rule: "Host(`traefik.slotpoll.yourdomain.com`)"
      service: api@internal
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt
      middlewares:
        - dashboard-auth

  services:
    slotpoll-service:
      loadBalancer:
        servers:
          - url: "http://slotpoll_app:3000"

  middlewares:
    secure-headers:
      headers:
        customRequestHeaders:
          X-Forwarded-Proto: "https"
          X-Forwarded-Ssl: "on"
        customResponseHeaders:
          X-Powered-By: ""
        frameDeny: true
        contentTypeNosniff: true
        browserXssFilter: true
        referrerPolicy: "strict-origin-when-cross-origin"
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        permissionsPolicy: "camera=(), microphone=(), geolocation=()"
    dashboard-auth:
      basicAuth:
        users:
          # Generate with: htpasswd -nb admin YOUR_PASSWORD
          - "admin:$apr1$CHANGE_ME"
